rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function auth() { return request.auth; }
    function isLoggedIn() { return auth() != null; }

    function me() {
      return get(/databases/$(database)/documents/users/$(auth().uid)).data;
    }
    function isAdmin()   { return isLoggedIn() && me().role == 'admin'; }
    function isTeacher() { return isLoggedIn() && me().role == 'teacher'; }
    function isStudent() { return isLoggedIn() && me().role == 'student'; }
    function isOwner(uid) { return isLoggedIn() && auth().uid == uid; }

    // ── users ─────────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Students see only their own doc; teachers see all (for student name lookup)
      allow read: if isOwner(uid) || isAdmin() || isTeacher();
      // Only admin creates/updates other accounts; student can update own non-role fields
      allow create: if isAdmin();
      allow update: if isAdmin()
        || (isOwner(uid) && !('role' in request.resource.data.diff(resource.data).affectedKeys()));
    }

    // ── cohorts ───────────────────────────────────────────────────────────────
    match /cohorts/{id} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // ── milestones ────────────────────────────────────────────────────────────
    match /milestones/{id} {
      allow read: if isAdmin() || isTeacher()
        || (isStudent() && isOwner(resource.data.studentId));
      // Students submit their own; admin/teacher review (update status)
      allow create: if isAdmin()
        || (isStudent() && isOwner(request.resource.data.studentId));
      allow update: if isAdmin() || isTeacher();
      allow delete: if isAdmin() || isTeacher();
    }

    // ── internships ───────────────────────────────────────────────────────────
    match /internships/{id} {
      allow read: if isAdmin() || isTeacher()
        || (isStudent() && isOwner(resource.data.studentId));
      allow create: if isAdmin()
        || (isStudent() && isOwner(request.resource.data.studentId));
      allow update: if isAdmin() || isTeacher()
        || (isStudent() && isOwner(resource.data.studentId));
    }

    // ── hoursLogs ─────────────────────────────────────────────────────────────
    match /hoursLogs/{id} {
      allow read: if isAdmin() || isTeacher()
        || (isStudent() && isOwner(resource.data.studentId));
      allow create: if isAdmin()
        || (isStudent() && isOwner(request.resource.data.studentId));
      // Only teacher/admin can change status
      allow update: if isAdmin() || isTeacher();
    }

    // ── visitLogs ─────────────────────────────────────────────────────────────
    match /visitLogs/{id} {
      allow read: if isAdmin()
        || (isTeacher() && resource.data.tutorId == auth().uid)
        || (isStudent() && isOwner(resource.data.studentId));
      allow create: if isAdmin()
        || (isTeacher() && request.resource.data.tutorId == auth().uid);
      allow update: if isAdmin();
    }

    // ── masterClasses ─────────────────────────────────────────────────────────
    match /masterClasses/{id} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // ── skillsCatalog ─────────────────────────────────────────────────────────
    match /skillsCatalog/{id} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // ── mallaConfig ───────────────────────────────────────────────────────────
    match /mallaConfig/{id} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // ── empresas ──────────────────────────────────────────────────────────────
    match /empresas/{id} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }
  }
}
